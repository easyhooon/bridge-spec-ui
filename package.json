{
  "name": "bridge-spec-ui",
  "version": "0.0.0",
  "description": "Swagger UI-style documentation and testing components for WebView bridge APIs.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "sideEffects": [
    "dist/styles.css",
    "src/styles.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "dev": "vite --host 0.0.0.0",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "zod": ">=4"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.2",
    "zod": "^4.1.11"
  }
}
